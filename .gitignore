/dist
/target
/venv
__pycache__
*.pyc
*.pyo
*.pyd
*.wheel
*.egg
*.egg-info
*.log
cobertura.xml
coverage.xml
.DS_Store
*.jpg

# Test-output image dumps written into crate dirs by image comparison tests
# (e.g. crates/image/test_*.png). Tracked PNG fixtures live under testdata/.
/crates/image/*.png

*sbom.json
*.cdx.json

env.sh

# Ignore Local Notes — local caches of JIRA-style issues/tasks that
# avoid round-trips to the ticket system. Root-anchored so subcrates
# are free to ship legitimate files with these prefixes.
/TODO*.md
/BUG*.md
/FIX*.md
/FEATURE*.md
/SPS/
/WP1/
# Local-only planning / dev notes directory (never committed; use
# crate-level docs.rs comments or CHANGELOG.md for shipped docs).
/docs/
*.profraw
.remember

# Benchmark intermediate data (JSON results, logs)
/benchmarks/

# Local-only proof-of-concept spike projects. Each lives outside the
# workspace (its own Cargo.toml with `[workspace]` section) and gets
# folded into the main code or deleted once the experiment concludes.
/spikes/

# C API build artifacts
crates/capi/build/

# Large binary model artifacts kept outside the repo. Tracked fixtures
# (testdata/decoder/*.safetensors) survive because gitignore only
# affects untracked files; new vetted fixtures need `git add -f`.
*.tflite
*.onnx
